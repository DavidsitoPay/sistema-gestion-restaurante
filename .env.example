# Variables de entorno — copia este archivo como .env y ajusta los valores

# Base de datos MySQL
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/restaurante_db

# JWT Secret (cambia esto en producción)
SECRET_KEY=supersecretkey-change-in-production-please

# Tiempo de expiración del token en minutos (8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480
